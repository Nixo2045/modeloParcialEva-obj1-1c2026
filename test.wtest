import evas.*
import pilotos.*
import cuartel.*

describe "Test de pilotos, evas y cuartel" {
    test "El EVA-01 no puede usarse más de 3 veces seguidas sin recargarse" {
        eva01.efectoDeSincroCon(rei)
        eva01.efectoDeSincroCon(rei)
        eva01.efectoDeSincroCon(rei)

        assert.notThat(eva01.puedeSincronizarCon(rei) )
    }
    test "En modo ataque, el EVA-02 otorga 3 de entrenamiento y consume 20 de energía." {
        eva02.cambiarModo(ataque)
        eva02.efectoDeSincroCon(asuka)

        assert.equals(100 - 20, eva02.energia())
    }
    test "Shinji puede al inicio sincronizar con el EVA-00." {
        assert.that(shinji.puedeSincronizarCon(eva00))
    }
    test "Probar que Rei no puede realizar más de 5 sincronizaciones en total." {
        rei.efectoDeSincroCon(eva01)
        rei.efectoDeSincroCon(eva01)
        rei.efectoDeSincroCon(eva01)
        rei.efectoDeSincroCon(eva01)
        rei.efectoDeSincroCon(eva01)
        rei.efectoDeSincroCon(eva01)

        assert.notThat(rei.puedeSincronizarCon(eva01))
    }

    test "El cálculo del promedio de puntos de entrenamiento de los pilotos es correcto." {
        nerv.registrarPiloto(rei)
        nerv.registrarPiloto(shinji)
        nerv.registrarPiloto(asuka)
        nerv.registrarEva(eva01)
        nerv.registrarEva(eva02)
        nerv.registrarEva(eva00)
        
        assert.equals(2.33333, nerv.promedioPuntosDeEntrenamientoDePilotos())
    }

    test "Verificar que cada EVA puede ser usado por al menos un piloto registrado en el cuartel." {
        nerv.registrarPiloto(rei)
        nerv.registrarPiloto(shinji)
        nerv.registrarPiloto(asuka)
        nerv.registrarEva(eva01)
        nerv.registrarEva(eva02)
        nerv.registrarEva(eva00)

        assert.notThat(nerv.todosLosPilotosPuedenSincronizar())
    }

    test "Que un piloto se considera satisfecho según su definición personal." {
        rei.efectoDeSincroCon(eva01)

        assert.that(rei.estaSatisfecho())
    }
}